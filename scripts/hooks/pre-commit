#!/usr/bin/env bash
# Vita design-token gate — barra DÍVIDA NOVA de design, não o legado.
#
# Por que existe: o design system tem tokens centrais (VitaColors/VitaTokens/
# PixioTypo) mas as telas hardcodavam cor/fonte/raio → "muda 1" não mudava o
# app. Este gate impede que ENTRE valor mágico novo. Legado migra por fase;
# aqui só olhamos linhas ADICIONADAS (^+) no staged diff.
#
# Regra: em VitaAI/Features/** e VitaAI/**/Screen*.swift, PROIBIDO adicionar
#   - Color(red:  / Color(.sRGB / #hex literal   → use VitaColors.<token>
#   - .font(.system(size:                        → use PixioTypo.* / VitaTypography
#   - cornerRadius: <número>                     → use VitaTokens.Radius.*
# DesignSystem/** é isento (é onde as cores/rampas legitimamente vivem).
# Escape pontual: terminar a linha com  // ds-allow: <motivo>
set -euo pipefail

RED='\033[0;31m'; YEL='\033[1;33m'; NC='\033[0m'
violations=0
report() { printf "${RED}✗ %s${NC}\n   %s\n   → %s\n" "$1" "$2" "$3"; violations=$((violations+1)); }

# arquivos Swift staged, só em Features (telas), fora de DesignSystem
files=$(git diff --cached --name-only --diff-filter=ACM -- 'VitaAI/Features/*.swift' 'VitaAI/Features/**/*.swift' | grep -v '/DesignSystem/' || true)

for f in $files; do
  [ -f "$f" ] || continue
  # só linhas adicionadas, sem o marcador de escape
  added=$(git diff --cached -U0 -- "$f" | grep '^+' | grep -v '^+++' | grep -v 'ds-allow' || true)
  [ -z "$added" ] && continue

  while IFS= read -r line; do
    body=${line#+}
    if printf '%s' "$body" | grep -qE 'Color\(red:|Color\(\.sRGB|#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?["'\'' )]'; then
      report "$f" "$(printf '%s' "$body" | sed 's/^[[:space:]]*//' | cut -c1-72)" "cor crua → VitaColors.<token> (ou // ds-allow: motivo)"
    fi
    if printf '%s' "$body" | grep -qE '\.font\(\.system\(size:'; then
      report "$f" "$(printf '%s' "$body" | sed 's/^[[:space:]]*//' | cut -c1-72)" "fonte crua → PixioTypo.* / VitaTypography"
    fi
    if printf '%s' "$body" | grep -qE 'cornerRadius:[[:space:]]*[0-9]'; then
      report "$f" "$(printf '%s' "$body" | sed 's/^[[:space:]]*//' | cut -c1-72)" "raio cru → VitaTokens.Radius.*"
    fi
  done <<< "$added"
done

if [ "$violations" -gt 0 ]; then
  printf "\n${RED}Gate de design: %s violação(ões) de token em telas novas.${NC}\n" "$violations"
  printf "${YEL}Corrija usando o token, ou justifique com  // ds-allow: <motivo>  no fim da linha.${NC}\n"
  printf "Doutrina: VitaAI/DesignSystem/DESIGN.md\n"
  exit 1
fi
exit 0
